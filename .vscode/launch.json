{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "fib",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/src/cli.tsx",
            "args": [
                "fib",
                "10",
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal"
        },
    ]
}
