{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx"
  },
  "include": ["src", "test", "eslint.config.js", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
